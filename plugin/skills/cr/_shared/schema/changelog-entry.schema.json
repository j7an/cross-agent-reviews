{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://j7an.github.io/cross-agent-reviews/schema/v1/changelog-entry.json",
  "title": "ChangelogEntry",
  "type": "object",
  "additionalProperties": false,
  "required": ["finding_id", "change_made"],
  "properties": {
    "finding_id": {"type": "string", "pattern": "^R[123]-[1-6]-[0-9]{3}$"},
    "change_made": {"type": "string", "minLength": 1}
  }
}
